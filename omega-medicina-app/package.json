{
  "name": "omega-medicina-app",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testPathPatterns=src/services",
    "test:integration": "jest --testPathPatterns=src/components",
    "test:e2e": "detox test --configuration ios.simulator",
    "test:e2e:android": "detox test --configuration android.emu.debug",
    "test:e2e:build": "detox build --configuration ios.simulator",
    "test:e2e:build:android": "detox build --configuration android.emu.debug",
    "test:ci": "jest --coverage --watchAll=false",
    "mock:init": "node scripts/mock-data.js init",
    "mock:populate": "node scripts/mock-data.js populate",
    "mock:reset": "node scripts/mock-data.js reset",
    "mock:stats": "node scripts/mock-data.js stats",
    "test:all": "node scripts/run-tests.js",
    "test:quick": "node scripts/run-tests.js unit integration",
    "test:full": "node scripts/run-tests.js all --skip-e2e",
    "lint": "eslint src/ --ext .ts,.tsx",
    "lint:fix": "eslint src/ --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@faker-js/faker": "^8.4.1",
    "@hookform/resolvers": "^3.3.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@tanstack/react-query": "^5.28.0",
    "date-fns": "^3.6.0",
    "expo": "~54.0.0",
    "expo-constants": "~18.0.13",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-linking": "~8.0.11",
    "expo-notifications": "~0.32.16",
    "expo-print": "~15.0.8",
    "expo-router": "~6.0.22",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "lucide-react-native": "^0.344.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.51.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "^0.5.1",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.4.5",
    "@types/jest": "^30.0.0",
    "@types/react": "~18.3.0",
    "detox": "^20.14.3",
    "jest": "^30.2.0",
    "jest-fetch-mock": "^3.0.3",
    "msw": "^1.3.3",
    "ts-jest": "^29.4.6",
    "typescript": "~5.3.0"
  },
  "private": true
}
